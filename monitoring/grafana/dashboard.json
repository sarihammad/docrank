{
  "__inputs": [],
  "__requires": [],
  "annotations": {
    "list": []
  },
  "description": "DocRank RAG Platform — Request latency, retrieval, reranking, and generation metrics.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": { "legend": { "displayMode": "list" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(docrank_query_latency_seconds_bucket[5m])) by (le, endpoint))",
          "legendFormat": "p50 {{endpoint}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(docrank_query_latency_seconds_bucket[5m])) by (le, endpoint))",
          "legendFormat": "p95 {{endpoint}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(docrank_query_latency_seconds_bucket[5m])) by (le, endpoint))",
          "legendFormat": "p99 {{endpoint}}",
          "refId": "C"
        }
      ],
      "title": "Query Latency (p50 / p95 / p99)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "ms" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(docrank_retrieval_latency_ms_bucket[5m])) by (le))",
          "legendFormat": "Retrieval p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(docrank_reranking_latency_ms_bucket[5m])) by (le))",
          "legendFormat": "Reranking p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(docrank_generation_latency_ms_bucket[5m])) by (le))",
          "legendFormat": "Generation p95",
          "refId": "C"
        }
      ],
      "title": "Stage Latency p95 (ms)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "targets": [
        {
          "expr": "sum(rate(docrank_queries_total[1m])) by (mode)",
          "legendFormat": "{{mode}}",
          "refId": "A"
        }
      ],
      "title": "Query Throughput by Mode",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "sum(docrank_queries_total)",
          "legendFormat": "Total Queries",
          "refId": "A"
        },
        {
          "expr": "sum(docrank_cache_hits_total)",
          "legendFormat": "Cache Hits",
          "refId": "B"
        }
      ],
      "title": "Cumulative Counters",
      "type": "stat"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["docrank", "rag", "ml"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "DocRank — RAG Platform",
  "uid": "docrank-main",
  "version": 1
}
