API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
HYBRID_BM25_WEIGHT=0.5
HYBRID_DENSE_WEIGHT=0.5
LLM_JUDGE_MODEL=gpt-4o-mini
HALLUCINATION_THRESHOLD=0.5
